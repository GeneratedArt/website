CLOUDFLARE_KV_INDEXER_STATE_ID = "20884d2a97504b82822f34b6dc725e02"
CLOUDFLARE_KV_NAMESPACE_ID = "4c07b557b1b64e9dbe4b76427328c54a"
CLOUDFLARE_R2_BUCKET_NAME = "generatedart-assets"
CLOUDFLARE_QUEUE_NAME = "render-jobs"
CLOUDFLARE_ZONE_ID = "5f16e1194f7d4b9f508b955e49c7c6ad"
CLOUDFLARE_PROJECT_NAME = "generatedart-website"
